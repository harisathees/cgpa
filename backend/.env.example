# ── MySQL (Prisma) ────────────────────────────────────────────────────────────
# mysql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL="mysql://root:password@localhost:3306/cgpa"

# ── JWT auth ──────────────────────────────────────────────────────────────────
# Use a long random string in production, e.g. `openssl rand -hex 32`.
JWT_SECRET="change-me-to-a-long-random-secret"
JWT_EXPIRES_IN="7d"

# ── Admin seed ────────────────────────────────────────────────────────────────
# Credentials for the ADMIN account created by `npm run prisma:seed`.
ADMIN_EMAIL="admin@cgpa.local"
ADMIN_PASSWORD="admin12345"

# ── App ───────────────────────────────────────────────────────────────────────
PORT=3001
# Allowed CORS origin for the Next.js frontend.
FRONTEND_URL="http://localhost:3000"
