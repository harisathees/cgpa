# ──────────────────────────────────────────────────────────────────────────────
# Example environment for the Docker dev stack (docker-compose.dev.yml).
#
# Copy this file to `docker.env` and adjust as needed:
#     cp docker.env.example docker.env
#
# These values drive `docker compose` variable substitution and are passed into
# the backend container. The defaults below are fine for LOCAL DEV — but set a
# real JWT_SECRET before doing anything that matters.
# ──────────────────────────────────────────────────────────────────────────────

# ── Database (MariaDB service) ──────────────────────────────────────────────
# Note: inside the stack the API reaches the DB at host `db` (the compose
# service name), NOT localhost. DB_PORT only affects the host->container port
# mapping for tools like Prisma Studio / a GUI client.
DB_ROOT_PASSWORD=password
DB_NAME=cgpa
DB_PORT=3306

# ── JWT auth ────────────────────────────────────────────────────────────────
# Generate a real secret with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=change-me-to-a-long-random-secret
JWT_EXPIRES_IN=7d

# ── Admin seed (created by `npm run prisma:seed`) ───────────────────────────
ADMIN_EMAIL=admin@cgpa.local
ADMIN_PASSWORD=admin12345

# ── App ─────────────────────────────────────────────────────────────────────
# Host port the API is exposed on (container always listens on 3001).
PORT=3001
FRONTEND_URL=http://localhost:3000
